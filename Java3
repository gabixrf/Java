package teste.gds;

public class Gds {

    static class Produto {
        private String nome;
        private double nota1;
        private double nota2;

        // construtor com parâmetros
        public Produto(String nome, double nota1, double nota2) {
            this.nome = nome;
            this.nota1 = nota1;
            this.nota2 = nota2;
        }

        public double calcularMedia() {
           double media = (nota1+nota2)/ 2;
           return media;
        }
        
        public String avaliarSituacao() {
        double media = calcularMedia(); // pega a média do aluno

        if (media >= 7) {
            return "Aprovado";
        } else if (media >= 5) {
            return "Recuperação";
        } else {
            return "Reprovado";
        }
        }
    }
    
    public static void main(String[] args) {
    Produto p = new Produto("João", 8.5, 6);

    // mostrando a média
    System.out.println("Média: " + p.calcularMedia());

    // mostrando a situação
    System.out.println("Situação: " + p.avaliarSituacao());
    }
}
