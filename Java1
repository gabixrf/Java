public class Gds {

    static class Pessoa {
        private String nome;
        private int idade;

         // GET → pegar o valor
        public String getNome() {
            return nome;
        }
        public int getIdade(){
            return idade;
        }
        

        // SET → alterar o valor
        public void setNome(String nome) {
            this.nome = nome;
        }
        public void setIdade(int idade){
            this.idade= idade;
        }
    }

    public static void main(String[] args) {
        Pessoa p = new Pessoa();

        p.setNome("João");
        System.out.println(p.getNome());
        p.setIdade(17);
        System.out.println((char) p.getIdade());
    }
}
